---
import { aboutInformation } from '../../constants/about';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{aboutInformation.firstName} {aboutInformation.lastName}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0e0f13;
      --surface: #14161d;
      --surface2: #1c1f2b;
      --border: rgba(255,255,255,0.07);
      --border2: rgba(255,255,255,0.12);
      --accent: #4f8ef7;
      --accent2: #a78bfa;
      --text: #e8eaf0;
      --text2: #a1a3a6;
      --muted: #f5f8ff;
      --gold: #c9a84c;
      --green: #34d399;
      --orange: #fb923c;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lato', sans-serif;
      background-color: var(--bg);
      color: var(--text);
      line-height: 1.7;
      min-height: 100vh;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 0; opacity: 0.4;
    }

    /* ── HEADER ── */
    header {
      position: relative; padding: 2.5rem 3rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(180deg, rgba(79,142,247,0.04) 0%, transparent 100%);
      z-index: 10;
    }
    .header-name { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; }
    .header-name span { color: var(--accent); }
    nav { display: flex; gap: 0.25rem; }
    nav a {
      font-family: 'JetBrains Mono', monospace; font-size: 0.72rem;
      color: var(--muted); text-decoration: none; padding: 0.4rem 0.9rem;
      border-radius: 4px; border: 1px solid transparent;
      transition: all 0.2s; letter-spacing: 0.04em;
    }
    nav a:hover, nav a.active { color: var(--text); border-color: var(--border); background: var(--surface2); }

    /* ── HERO ── */
    .hero { padding: 2rem 3rem 0.5rem; max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }
    .eyebrow {
      font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
      letter-spacing: 0.2em; color: var(--accent); text-transform: uppercase;
      margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0rem;
    }
    .eyebrow::after { content: ''; flex: 1; max-width: 60px; height: 1px; background: var(--accent); opacity: 0.4; }
    .hero h1 {
      font-family: 'Playfair Display', serif; font-size: clamp(2.8rem, 6vw, 4.5rem);
      font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 0.2rem;
      color: #ffffff;
    }
    .hero h0 em { font-style: italic; color: var(--accent2); }
    .hero-meta { display: flex; gap: 2.5rem; margin-top: 0rem; flex-wrap: wrap; }
    .hero-stat { display: flex; flex-direction: column; gap: 0.1rem; }
    .hero-stat-num { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--accent); line-height: 1; }
    .hero-stat-label { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--text2); letter-spacing: 0.1em; text-transform: uppercase; }
    .hero-links { display: flex; gap: 1.5rem; margin-top: 0.5rem; flex-wrap: wrap; }
    .hero-link { font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; color: var(--text2); text-decoration: none; display: flex; align-items: center; gap: 0.5rem; transition: color 0.2s; }
    .hero-link svg { width: 14px; height: 14px; flex-shrink: 0; }
    .hero-link:hover { color: var(--accent); }

    /* ── PUBLICATIONS LIST ── */
    .pub-section {
      padding: 2rem 3rem 6rem;
      max-width: 900px;
      margin: 0 auto;
      position: relative; z-index: 1;
    }

    #allPubs {
      max-height: 600px;
      overflow-y: auto;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 0 0.5rem;
      scrollbar-width: thin;
      scrollbar-color: rgba(8, 8, 8, 0.3) transparent;
    }
    #allPubs::-webkit-scrollbar { width: 4px; }
    #allPubs::-webkit-scrollbar-track { background: transparent; }
    #allPubs::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.3); border-radius: 2px; }
    #allPubs::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.6); }

    .pub-list-item {
      display: grid;
      grid-template-columns: 36px 1fr;
      gap: 0 1.25rem;
      padding: 1.25rem 0.75rem;
      border-bottom: 1px solid var(--border);
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .pub-list-item:last-child { border-bottom: none; }
    .pub-list-item:hover { background: var(--surface2); }
    .pub-list-item:hover .pli-title { color: var(--accent); }
    .pub-list-item:hover .pli-index { color: var(--accent); }
    .pub-list-item[data-url=""] { cursor: default; }
    .pub-list-item[data-url=""]:hover { background: transparent; }
    .pub-list-item[data-url=""]:hover .pli-title { color: var(--text); }
    .pub-list-item[data-url=""]:hover .pli-index { color: var(--border2); }

    .pli-index {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem; font-weight: 700;
      color: var(--border2); line-height: 1;
      transition: color 0.2s; padding-top: 0.15rem;
      text-align: right;
    }

    .pli-body { min-width: 0; }

    .pli-meta {
      display: flex; align-items: center; flex-wrap: wrap;
      gap: 0.4rem; margin-bottom: 0.25rem;
    }
    .pli-venue {
      font-family: 'JetBrains Mono', monospace; font-size: 0.6rem;
      color: var(--gold); letter-spacing: 0.04em;
    }
    .pli-dot {
      width: 2px; height: 2px; border-radius: 50%;
      background: var(--muted); flex-shrink: 0;
    }

    .pli-title {
      font-family: 'Playfair Display', serif; font-size: 0.95rem; font-weight: 700;
      line-height: 1.35; color: var(--text); transition: color 0.2s; margin-bottom: 0.3rem;
    }
    .pli-authors { font-size: 0.72rem; color: var(--muted); line-height: 1.5; }
    .pli-authors strong { color: var(--accent2); font-weight: 400; }

    /* ── Status badges ── */
    .status-badge {
      font-family: 'JetBrains Mono', monospace; font-size: 0.52rem;
      letter-spacing: 0.08em; text-transform: uppercase;
      padding: 0.1rem 0.45rem; border-radius: 4px; border: 1px solid;
      white-space: nowrap;
    }
    .badge-published { color: var(--green); border-color: rgba(52,211,153,0.25); background: rgba(52,211,153,0.06); }
    .badge-review    { color: var(--orange); border-color: rgba(251,146,60,0.25); background: rgba(251,146,60,0.06); }
    .badge-submitted { color: var(--accent2); border-color: rgba(167,139,250,0.25); background: rgba(167,139,250,0.06); }
    .badge-notpeer   { color: var(--muted); border-color: var(--border); background: transparent; }

    /* ── FOOTER ── */
    footer { border-top: 1px solid var(--border); padding: 2rem 3rem; position: relative; z-index: 1; }
    .footer-inner { max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
    .footer-copy { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: var(--muted); letter-spacing: 0.05em; }
    .footer-social { display: flex; gap: 0.5rem; }
    .footer-social a { width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; border-radius: 8px; border: 1px solid var(--border); color: var(--muted); background: var(--surface); transition: all 0.2s; }
    .footer-social a:hover { color: var(--accent); border-color: rgba(79,142,247,0.4); background: var(--surface2); }
    .footer-social svg { width: 15px; height: 15px; }

    @media (max-width: 700px) {
      header { flex-direction: column; gap: 1.5rem; padding: 2rem 1.5rem; }
      .hero, .pub-section { padding-left: 1.5rem; padding-right: 1.5rem; }
      .footer-inner { flex-direction: column; gap: 1.5rem; align-items: center; }
    }
  </style>
</head>
