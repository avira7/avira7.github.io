---
import { aboutInformation } from '../../constants/about';
import { publicationInformation } from '../../constants/publications';

const badgeClass: Record<string, string> = {
  published: 'badge-published',
  review:    'badge-review',
  submitted: 'badge-submitted',
  notpeer:   'badge-notpeer',
};

const badgeLabel: Record<string, string> = {
  published: 'Published',
  review:    'Under Review',
  submitted: 'Submitted',
  notpeer:   'Not Peer Reviewed',
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{aboutInformation.firstName} {aboutInformation.lastName}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0e0f13;
      --surface: #14161d;
      --surface2: #1c1f2b;
      --border: rgba(255,255,255,0.07);
      --border2: rgba(255,255,255,0.12);
      --accent: #4f8ef7;
      --accent2: #a78bfa;
      --text: #e8eaf0;
      --text2: #a1a3a6;
      --muted: #f5f8ff;
      --gold: #c9a84c;
      --green: #34d399;
      --orange: #fb923c;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lato', sans-serif;
      background-color: var(--bg);
      color: var(--text);
      line-height: 1.7;
      min-height: 100vh;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 0; opacity: 0.4;
    }

    /* ── HERO ── */
    .hero { padding: 2rem 3rem 0.5rem; max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }
    .hero h1 {
      font-family: 'Playfair Display', serif; font-size: clamp(2.8rem, 6vw, 4.5rem);
      font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 0.2rem;
      color: #ffffff;
    }
    .hero-meta { display: flex; gap: 2.5rem; margin-top: 0rem; flex-wrap: wrap; }
    .hero-stat { display: flex; flex-direction: column; gap: 0.1rem; }
    .hero-stat-num { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--accent); line-height: 1; }
    .hero-stat-label { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--text2); letter-spacing: 0.1em; text-transform: uppercase; }
    .hero-links { display: flex; gap: 1.5rem; margin-top: 0.5rem; flex-wrap: wrap; }
    .hero-link { font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; color: var(--text2); text-decoration: none; display: flex; align-items: center; gap: 0.5rem; transition: color 0.2s; }
    .hero-link svg { width: 14px; height: 14px; flex-shrink: 0; }
    .hero-link:hover { color: var(--accent); }

    /* ── PUBLICATIONS LIST ── */
    .pub-section {
      padding: 2rem 3rem 4rem;
      max-width: 900px;
      margin: 0 auto;
      position: relative; z-index: 1;
    }

    #allPubs {
      max-height: 600px;
      overflow-y: auto;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 0 0.5rem;
      scrollbar-width: thin;
      scrollbar-color: rgba(8, 8, 8, 0.3) transparent;
    }
    #allPubs::-webkit-scrollbar { width: 4px; }
    #allPubs::-webkit-scrollbar-track { background: transparent; }
    #allPubs::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.3); border-radius: 2px; }
    #allPubs::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.6); }

    .pub-list-item {
      display: grid;
      grid-template-columns: 36px 1fr;
      gap: 0 1.25rem;
      padding: 1.25rem 0.75rem;
      border-bottom: 1px solid var(--border);
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .pub-list-item:last-child { border-bottom: none; }
    .pub-list-item:hover { background: var(--surface2); }
    .pub-list-item:hover .pli-title { color: var(--accent); }
    .pub-list-item:hover .pli-index { color: var(--accent); }
    .pub-list-item[data-url=""] { cursor: default; }
    .pub-list-item[data-url=""]:hover { background: transparent; }
    .pub-list-item[data-url=""]:hover .pli-title { color: var(--text); }
    .pub-list-item[data-url=""]:hover .pli-index { color: var(--border2); }

    .pli-index {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem; font-weight: 700;
      color: var(--border2); line-height: 1;
      transition: color 0.2s; padding-top: 0.15rem;
      text-align: right;
    }

    .pli-body { min-width: 0; }

    .pli-meta {
      display: flex; align-items: center; flex-wrap: wrap;
      gap: 0.4rem; margin-bottom: 0.25rem;
    }
    .pli-venue {
      font-family: 'JetBrains Mono', monospace; font-size: 0.6rem;
      color: var(--gold); letter-spacing: 0.04em;
    }
    .pli-dot {
      width: 2px; height: 2px; border-radius: 50%;
      background: var(--muted); flex-shrink: 0;
    }

    .pli-title {
      font-family: 'Playfair Display', serif; font-size: 0.95rem; font-weight: 700;
      line-height: 1.35; color: var(--text); transition: color 0.2s; margin-bottom: 0.3rem;
    }
    .pli-authors { font-size: 0.72rem; color: var(--muted); line-height: 1.5; }
    .pli-authors :global(strong) { color: var(--accent2); font-weight: 700; }

    /* ── Status badges ── */
    .status-badge {
      font-family: 'JetBrains Mono', monospace; font-size: 0.52rem;
      letter-spacing: 0.08em; text-transform: uppercase;
      padding: 0.1rem 0.45rem; border-radius: 4px; border: 1px solid;
      white-space: nowrap;
    }
    .badge-published { color: var(--green); border-color: rgba(52,211,153,0.25); background: rgba(52,211,153,0.06); }
    .badge-accepted { color: var(--green); border-color: rgba(52,211,153,0.25); background: rgba(52,211,153,0.06); }
    .badge-review    { color: var(--orange); border-color: rgba(251,146,60,0.25); background: rgba(251,146,60,0.06); }
    .badge-submitted { color: var(--accent2); border-color: rgba(167,139,250,0.25); background: rgba(167,139,250,0.06); }
    .badge-notpeer   { color: var(--muted); border-color: var(--border); background: transparent; }

    @media (max-width: 700px) {
      .hero, .pub-section { padding-left: 1.5rem; padding-right: 1.5rem; }
    }
  </style>
</head>
<body>

  <div class="hero">
    <h1>Publications</h1>
    <div class="hero-links">
      <a href={aboutInformation.googlescholar} target="_blank" class="hero-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 14l9-5-9-5-9 5 9 5z"/><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0112 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
        Google Scholar
      </a>
      <a href={aboutInformation.orcid} target="_blank" class="hero-link">
        <svg viewBox="0 0 24 24" fill="currentColor" style="width:14px;height:14px;"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.516.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.016-5.325 5.016h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>
        ORCiD
      </a>
      <a href={aboutInformation.researchgate} target="_blank" class="hero-link">
        <svg viewBox="0 0 24 24" fill="currentColor" style="width:14px;height:14px;"><path d="M19.586 0H4.414A4.414 4.414 0 000 4.414v15.172A4.414 4.414 0 004.414 24h15.172A4.414 4.414 0 0024 19.586V4.414A4.414 4.414 0 0019.586 0zM14.67 17.32h-2.204v-4.41h-.73v4.41H9.532V6.68h3.394c1.88 0 3.054.959 3.054 2.74 0 1.168-.523 1.972-1.424 2.39l1.756 3.026-.01.013-.633-1.09v3.561zm-2.934-6.138h1.12c.808 0 1.292-.44 1.292-1.214 0-.796-.484-1.17-1.47-1.17h-.942v2.384z"/></svg>
        Research Gate
      </a>
    </div>
    <div class="hero-meta">
      <div class="hero-stat">
        <span class="hero-stat-num">{publicationInformation.stats.published}</span>
        <span class="hero-stat-label">Published</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-num">{publicationInformation.stats.underReview}</span>
        <span class="hero-stat-label">Under Review</span>
      </div>
    </div>
  </div>

  <div class="pub-section">
    <div id="allPubs">
      {publicationInformation.publications.map((pub) => (
        <div class="pub-list-item" data-url={pub.url ?? ""}>
          <span class="pli-index">{String(pub.id).padStart(2, '0')}</span>
          <div class="pli-body">
            <div class="pli-meta">
              <span class="pli-venue">{pub.venue} · {pub.year}</span>
              <span class="pli-dot"></span>
              <span class={`status-badge ${badgeClass[pub.status]}`}>
                {badgeLabel[pub.status]}
              </span>
              {pub.tags?.map((tag) => (
                <>
                  <span class="pli-dot"></span>
                  <span class="status-badge badge-notpeer">{tag}</span>
                </>
              ))}
            </div>
            <div class="pli-title">{pub.title}</div>
            <div class="pli-authors" set:html={pub.authors} />
          </div>
        </div>
      ))}
    </div>
  </div>

  <script>
    document.querySelectorAll('.pub-list-item[data-url]').forEach(item => {
      item.addEventListener('click', () => {
        const url = (item as HTMLElement).dataset.url;
        if (url) window.open(url, '_blank');
      });
    });
  </script>

</body>
</html>