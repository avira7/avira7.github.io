---
import { aboutInformation } from '../../constants/about';
import { newsUpdates } from '../../constants/news';

// Sort news updates chronologically (most recent first) and take top 3
const sortedNews = newsUpdates
  .sort((a, b) => {
    const dateA = new Date(a.date.replace(/\[|\]/g, ''));
    const dateB = new Date(b.date.replace(/\[|\]/g, ''));
    return dateB.getTime() - dateA.getTime();
  })
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{aboutInformation.firstName} {aboutInformation.lastName}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=JetBrains+Mono:wght@400;500&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0e0f13;
      --surface: #14161d;
      --surface2: #1c1f2b;
      --surface3: #222638;
      --border: rgba(255,255,255,0.07);
      --border2: rgba(255,255,255,0.12);
      --accent: #4f8ef7;
      --accent2: #a78bfa;
      --text: #e8eaf0;
      --text2: #a1a3a6;
      --muted: #dfe1e4;
      --gold: #c9a84c;
      --green: #34d399;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lato', sans-serif;
      background-color: var(--bg);
      color: var(--text);
      line-height: 1.7;
      min-height: 100vh;
    }

    /* ── GRID BACKGROUND PATTERN (BGPattern: grid + fade-edges) ── */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image:
        linear-gradient(to right, rgba(255, 255, 255, 0.56) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255, 255, 255, 0.51) 1px, transparent 1px);
      background-size: 40px 40px;
      mask-image: radial-gradient(ellipse at center, transparent 10%, var(--bg) 75%);
      -webkit-mask-image: radial-gradient(ellipse at center, transparent 10%, var(--bg) 75%);
      pointer-events: none;
      z-index: 0;
    }

    /* ── NOISE GRAIN (layered on top of grid) ── */
    body::after {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 0; opacity: 0.4;
    }

    /* ── PAGE WRAPPER ── */
    .page { max-width: 900px; margin: 0 auto; padding: 0rem 3rem 3rem; position: relative; z-index: 1; }

    /* ── EYEBROW ── */
    .eyebrow {
      font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
      letter-spacing: 0.2em; color: var(--accent); text-transform: uppercase;
      margin-bottom: 5rem; display: flex; align-items: center; gap: 0.8rem;
      opacity: 0; animation: fadeUp 0.6s ease 0.05s forwards;
    }
    .eyebrow::after { content: ''; flex: 1; max-width: 60px; height: 1px; background: var(--accent); opacity: 0.4; }

    /* ════════════════════════════
       EDITORIAL CARD
    ════════════════════════════ */
    .member-card {
      position: relative;
      margin-top: 2.5rem;
      margin-bottom: 2rem;
      opacity: 0; animation: fadeIn 0.7s ease 0.1s forwards;
    }

    .member-position {
      font-family: 'JetBrains Mono', monospace; font-size: 0.68rem;
      letter-spacing: 0.3em; color: var(--muted); text-transform: uppercase;
      margin-bottom: 1.25rem;
      opacity: 0; animation: fadeUp 0.5s ease 0.15s forwards;
    }

    .member-body {
      display: flex;
      align-items: flex-start;
      gap: 3rem;
    }

    /* Portrait column — portrait + CV button stacked */
    .member-portrait-col {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      flex-shrink: 0;
      width: 360px;
      opacity: 0;
      animation: portraitReveal 0.8s cubic-bezier(0.22,1,0.36,1) 0.2s forwards;
    }

    .member-portrait {
      position: relative;
      width: 100%;
      height: 480px;
      overflow: hidden;
    }

    .member-portrait::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 60%);
      pointer-events: none; z-index: 1;
    }

    .member-portrait img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center top;
      transition: transform 0.5s cubic-bezier(0.22,1,0.36,1);
    }
    .member-portrait:hover img { transform: scale(1.05); }

    /* Download CV button */
    .cv-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.55rem;
      width: 100%;
      padding: 0.65rem 1.25rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text);
      background: var(--surface2);
      border: 1px solid var(--border2);
      border-radius: 6px;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.15s;
    }
    .cv-btn:hover {
      background: rgba(79,142,247,0.12);
      border-color: rgba(79,142,247,0.5);
      color: var(--accent);
      transform: translateY(-1px);
    }
    .cv-btn svg {
      width: 13px; height: 13px; flex-shrink: 0;
      transition: transform 0.2s;
    }
    .cv-btn:hover svg { transform: translateY(2px); }

    /* Info block */
    .member-info {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      padding-top: 0.5rem;
      opacity: 0;
      animation: slideInRight 0.7s cubic-bezier(0.22,1,0.36,1) 0.35s forwards;
    }

    .member-social {
      display: flex;
      gap: 0.2rem;
      margin-top: 0rem;
    }
    .member-social a {
      width: 28px; height: 28px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 6px;
      border: 1px solid var(--border);
      color: var(--muted);
      background: var(--surface);
      transition: all 0.2s;
    }
    .member-social svg { width: 12px; height: 12px; }
    .member-social a:hover {
      color: var(--accent);
      border-color: rgba(79,142,247,0.4);
      background: var(--surface2);
    }

    .member-name {
      font-family: 'Playfair Display', serif;
      line-height: 1.05;
      letter-spacing: -0.03em;
    }
    .member-name .first {
      font-size: clamp(3rem, 6vw, 5.5rem);
      font-weight: 300;
      display: block;
      color: var(--text);
    }
    .member-name .last {
      font-size: clamp(3rem, 6vw, 5.5rem);
      font-weight: 700;
      display: block;
      color: var(--text);
    }
    .member-name .last em {
      font-style: italic;
      color: var(--accent2);
    }

    /* Bio */
    .member-bio {
      font-size: 0.88rem;
      color: var(--text2);
      line-height: 1.9;
      max-width: 380px;
    }
    .member-bio strong { color: var(--muted); font-weight: 400; }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes portraitReveal {
      from { opacity: 0; transform: scale(0.96) translateY(24px); }
      to   { opacity: 1; transform: scale(1) translateY(0); }
    }
    @keyframes slideInRight {
      from { opacity: 0; transform: translateX(32px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    /* ── HEADER ── */
    header {
      position: relative; padding: 2.5rem 3rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(180deg, rgba(79,142,247,0.04) 0%, transparent 100%);
      z-index: 10;
    }
    .header-name { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; }
    .header-name span { color: var(--accent); }
    nav { display: flex; gap: 0.25rem; }
    nav a {
      font-family: 'JetBrains Mono', monospace; font-size: 0.72rem;
      color: var(--muted); text-decoration: none; padding: 0.4rem 0.9rem;
      border-radius: 4px; border: 1px solid transparent;
      transition: all 0.2s; letter-spacing: 0.04em;
    }
    nav a:hover, nav a.active { color: var(--text); border-color: var(--border); background: var(--surface2); }

    /* ── HERO ── */
    .hero { padding: 5rem 3rem 2rem; max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }
    .hero-eyebrow {
      font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
      letter-spacing: 0.2em; color: var(--accent); text-transform: uppercase;
      margin-bottom: 1.2rem; display: flex; align-items: center; gap: 0.8rem;
    }
    .hero-eyebrow::after { content: ''; flex: 1; max-width: 60px; height: 1px; background: var(--accent); opacity: 0.4; }

    /* ── FOOTER ── */
    footer { border-top: 1px solid var(--border); padding: 2rem 3rem; position: relative; z-index: 1; }
    .footer-inner { max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
    .footer-copy { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: var(--muted); letter-spacing: 0.05em; }
    .footer-social { display: flex; gap: 0.5rem; }
    .footer-social a { width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; border-radius: 8px; border: 1px solid var(--border); color: var(--muted); background: var(--surface); transition: all 0.2s; }
    .footer-social a:hover { color: var(--accent); border-color: rgba(79,142,247,0.4); background: var(--surface2); }
    .footer-social svg { width: 15px; height: 15px; }

    /* ── NEWS BANNER ── */
    .news-banner {
      margin-top: 1rem;
      padding: 1.5rem;
      padding-right: 0.75rem; /* tighter right pad so scrollbar sits flush */
      background: rgba(255, 255, 255, 0.75);
      border: 1px solid rgba(148, 163, 184, 0.5);
      border-radius: 8px;
      position: relative;
      z-index: 2;
      height: 200px;        /* fixed height — adjust to taste */
      display: flex;
      flex-direction: column;
    }

    .news-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      overflow-y: scroll;   /* always show scrollbar, not just on overflow */
      padding-right: 0.75rem;
      scrollbar-width: thin;
      scrollbar-color: rgba(109, 110, 112, 0.4) rgba(0, 0, 0, 0.05);
    }

    .news-content::-webkit-scrollbar { width: 4px; }
    .news-content::-webkit-scrollbar-track { background: rgba(0,0,0,0.05); border-radius: 2px; }
    .news-content::-webkit-scrollbar-thumb { background: rgba(79,142,247,0.4); border-radius: 2px; }

    .news-banner-header {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.75rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #1e293b;
      font-weight: 600;
    } 

    .news-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.3rem;
      padding: 0.125rem 0;
      border-bottom: 1px solid rgba(148, 163, 184, 0.2);
    }

    .news-item:last-child {
      border-bottom: none;
    }

    .banner-text {
      font-family: 'Lato', sans-serif;
      font-size: 0.95rem;
      color: #0b0b0b;
      line-height: 1.6;
      margin: 0;
      flex: 1;
    }

    .news-read-btn {
      font-family: 'Lato', sans-serif;
      font-size: 0.85rem;
      color: var(--accent);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.25rem 0.7rem;
      border: 1px solid rgba(79, 142, 247, 0.8);
      border-radius: 6px;
      transition: all 0.2s;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .news-read-btn:hover {
      background: rgba(79, 142, 247, 0.1);
      border-color: var(--accent);
    }

    @media (max-width: 800px) {
      header { flex-direction: column; gap: 1.5rem; padding: 2rem 1.5rem; }
      .page { padding: 4rem 1.5rem 6rem; }
      .member-body { flex-direction: column; gap: 2rem; }
      .member-portrait-col { width: 100%; }
      .member-portrait { height: 320px; }
      .footer-inner { flex-direction: column; gap: 1.5rem; align-items: center; }
      .news-banner { padding: 1.25rem; }
      .banner-label { font-size: 0.85rem; }
      .banner-text { font-size: 0.9rem; }
      .banner-link { width: 38px; height: 38px; }
    }
  </style>
</head>
<body>


  <div class="page">

    <!-- ── EDITORIAL CARD ── -->
    <div class="member-card">

      <div class="member-body">

        <!-- Portrait column: image + CV button -->
        <div class="member-portrait-col">
          <div class="member-portrait">
            <img
              src={aboutInformation.photo}
              alt="{aboutInformation.firstName} {aboutInformation.lastName}"
            />
          </div>
          <a href={aboutInformation.cv} download class="cv-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Download CV
          </a>
        </div>

        <!-- Info block -->
        <div class="member-info">
          <div class="member-name">
            <span class="first">{aboutInformation.firstName}</span>
            <span class="last"><em>{aboutInformation.lastName}</em></span>
          </div>

          <div class="member-social">
            <a href={`mailto:${aboutInformation.email}`} aria-label="Email">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>
            </a>
            <a href={aboutInformation.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href={aboutInformation.googlescholar} target="_blank" rel="noopener noreferrer" aria-label="Google Scholar">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 10a8 8 0 0 1 7.162 3.44L24 9.5z"/>
              </svg>
            </a>
            <a href={aboutInformation.orcid} target="_blank" rel="noopener noreferrer" aria-label="ORCID">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.516.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.016-5.325 5.016h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>
            </a>
            <a href={aboutInformation.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>
            </a>
          </div>

          <p class="member-bio" set:html={aboutInformation.bio}></p>
        </div>

          
        
        </div>

      </div>

      

      <!-- News Banner -->
      <div class="news-banner">
      <div class="news-banner-header">
        📰 News Feed
      </div>
        <div class="news-content">
          {sortedNews.map((news, index) => (
            <div class="news-item" key={news.title}>
              <p class="banner-text">
                <strong>{news.date}</strong> — {news.title}
              </p>
              {news.url && (
              <a href={news.url} class="news-read-btn" target="_blank" rel="noreferrer">
                Read
              </a>)}
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>

</body>
</html>