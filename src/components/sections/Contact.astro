---
import { aboutInformation } from '../../constants/about';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{aboutInformation.firstName} {aboutInformation.lastName}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0e0f13;
      --surface: #14161d;
      --surface2: #1c1f2b;
      --surface3: #222638;
      --border: rgba(255,255,255,0.07);
      --border2: rgba(255,255,255,0.12);
      --accent: #4f8ef7;
      --accent2: #a78bfa;
      --text: #e8eaf0;
      --text2: #a1a3a6;
      --muted: #6b7280;
      --gold: #c9a84c;
      --green: #34d399;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lato', sans-serif;
      background-color: var(--bg);
      color: var(--text);
      line-height: 1.7;
      min-height: 100vh;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 0; opacity: 0.4;
    }

    /* ── HEADER ── */
    header {
      position: relative; padding: 2.5rem 3rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(180deg, rgba(79,142,247,0.04) 0%, transparent 100%);
      z-index: 10;
    }
    .header-name { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; }
    .header-name span { color: var(--accent); }
    nav { display: flex; gap: 0.25rem; }
    nav a {
      font-family: 'JetBrains Mono', monospace; font-size: 0.72rem;
      color: var(--text2); text-decoration: none; padding: 0.4rem 0.9rem;
      border-radius: 4px; border: 1px solid transparent;
      transition: all 0.2s; letter-spacing: 0.04em;
    }
    nav a:hover, nav a.active { color: var(--text); border-color: var(--border); background: var(--surface2); }

    /* ── HERO ── */
    .hero { padding: 2rem 3rem 0.5rem; max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }
    .eyebrow {
      font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
      letter-spacing: 0.2em; color: var(--accent); text-transform: uppercase;
      margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.8rem;
    }
    .eyebrow::after { content: ''; flex: 1; max-width: 60px; height: 1px; background: var(--accent); opacity: 0.4; }
    .hero h1 {
      font-family: 'Playfair Display', serif; font-size: clamp(2.8rem, 6vw, 4.5rem);
      font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 0.5rem;
    }
    .hero h1 em { font-style: italic; color: var(--accent2); }
    .hero-sub {
      font-size: 1rem; color: var(--text2); max-width: 480px; line-height: 1.8;
    }

    /* ── MAIN CONTENT ── */
    .contact-section {
      padding: 2rem 3rem 6rem;
      max-width: 900px; margin: 0 auto;
      position: relative; z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    .card-canvas {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .card-backdrop {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(79,142,247,0.15) 0%, transparent 70%);
      filter: url(#unopaq);
      pointer-events: none;
    }

    .glow-card {
      position: relative;
      border-radius: 12px;
      background: rgba(20, 22, 29, 0.8);
      backdrop-filter: blur(12px);
      overflow: hidden;
    }

    .border-element {
      position: absolute;
      background: linear-gradient(90deg, transparent, rgba(79,142,247,0.6), transparent);
      pointer-events: none;
      z-index: 1;
    }
    .border-left   { left: 0; top: 0; width: 1px; height: 100%; background: linear-gradient(180deg, transparent, rgba(79,142,247,0.6), transparent); }
    .border-right  { right: 0; top: 0; width: 1px; height: 100%; background: linear-gradient(180deg, transparent, rgba(79,142,247,0.6), transparent); }
    .border-top    { top: 0; left: 0; height: 1px; width: 100%; }
    .border-bottom { bottom: 0; left: 0; height: 1px; width: 100%; }

    .card-content  { position: relative; z-index: 2; }

    /* ── CONTACT LIST ITEMS ── same .pub-list-item format ── */
    .contact-item {
      display: grid;
      grid-template-columns: 36px 1fr auto;
      gap: 0 1.25rem;
      padding: 1.4rem 0.75rem;
      border-bottom: 1px solid var(--border);
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.2s;
      text-decoration: none;
      color: inherit;
      align-items: center;
    }
    .contact-item:last-child { border-bottom: none; }
    .contact-item:hover { background: var(--surface2); }
    .contact-item:hover .ci-label { color: var(--accent); }
    .contact-item:hover .ci-icon-wrap { background: rgba(79,142,247,0.2); border-color: rgba(79,142,247,0.4); }
    .contact-item:hover .ci-icon-wrap svg { color: var(--accent); }
    .contact-item:hover .ci-arrow { opacity: 1; transform: translateX(0); color: var(--accent); }

    .ci-icon-wrap {
      width: 36px; height: 36px;
      border-radius: 8px;
      background: rgba(79,142,247,0.08);
      border: 1px solid var(--border2);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      transition: background 0.2s, border-color 0.2s;
    }
    .ci-icon-wrap svg { width: 16px; height: 16px; color: var(--muted); transition: color 0.2s; }

    .ci-body { min-width: 0; }
    .ci-type {
      font-family: 'JetBrains Mono', monospace; font-size: 0.6rem;
      color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase;
      margin-bottom: 0.15rem;
    }
    .ci-label {
      font-family: 'Playfair Display', serif; font-size: 0.95rem; font-weight: 700;
      color: var(--text); transition: color 0.2s;
      line-height: 1.3;
    }
    .ci-sublabel {
      font-family: 'JetBrains Mono', monospace; font-size: 0.68rem;
      color: var(--muted); margin-top: 0.1rem;
    }

    .ci-arrow {
      opacity: 0;
      transform: translateX(-6px);
      transition: opacity 0.2s, transform 0.2s, color 0.2s;
      flex-shrink: 0;
    }
    .ci-arrow svg { width: 16px; height: 16px; }

    /* ── FOOTER ── */
    footer { border-top: 1px solid var(--border); padding: 0rem 3rem; position: relative; z-index: 1; }
    .footer-inner { max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
    .footer-copy { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: var(--muted); letter-spacing: 0.05em; }
    .footer-social { display: flex; gap: 0.5rem; }
    .footer-social a { width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; border-radius: 8px; border: 1px solid var(--border); color: var(--muted); background: var(--surface); transition: all 0.2s; }
    .footer-social a:hover { color: var(--accent); border-color: rgba(79,142,247,0.4); background: var(--surface2); }
    .footer-social svg { width: 15px; height: 15px; }

    @media (max-width: 700px) {
      header { flex-direction: column; gap: 0rem; padding: 2rem 1.5rem; }
      .hero, .contact-section { padding-left: 1.5rem; padding-right: 1.5rem; }
      .footer-inner { flex-direction: column; gap: 1.5rem; align-items: center; }
      .contact-item { grid-template-columns: 36px 1fr; }
      .ci-arrow { display: none; }
    }
  </style>
</head>
<body>

  <div class="hero">
    <h1>Get in <em>touch</em></h1>
    <p class="hero-sub">Whether it's job opportunities, collaborations, or questions about my research — I would love to hear from you.</p>
  </div>

  <div class="contact-section">
    <div class="card-canvas">
      <div class="glow-card" style="width: 100%;">
        <div class="border-element border-left"></div>
        <div class="border-element border-right"></div>
        <div class="border-element border-top"></div>
        <div class="border-element border-bottom"></div>
        <div class="card-content">

      <!-- Email -->
      <a class="contact-item" href={`mailto:${aboutInformation.email}`} >
        <div class="ci-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>
        </div>
        <div class="ci-body">
          <div class="ci-type">Email</div>
          <div class="ci-label">{aboutInformation.email}</div>
          <div class="ci-sublabel">{aboutInformation.institution}</div>
        </div>
        <div class="ci-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>

      <!-- LinkedIn -->
      <a class="contact-item" href={aboutInformation.linkedin} target="_blank" rel="noopener noreferrer">
        <div class="ci-icon-wrap">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </div>
        <div class="ci-body">
          <div class="ci-type">LinkedIn</div>
          <div class="ci-label">{aboutInformation.linkedin}</div>
          <div class="ci-sublabel">Professional profile &amp; network</div>
        </div>
        <div class="ci-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>


      </div>
      </div>
    </div>
  </div>

</body>
</html>