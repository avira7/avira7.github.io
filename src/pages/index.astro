---
import About from '../components/sections/About.astro';
import Research from '../components/sections/Research.astro';
import Publications from '../components/sections/Publications.astro';
import Contact from '../components/sections/Contact.astro';
import { aboutInformation } from '../constants/about';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="google-site-verification" content="xLMTYiV5PxCqZjTz8oTogsEpn155XRu_ouGudAbDwBM" />
  <meta name="description" content={aboutInformation.bioPlain} />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-HN4SQRP2M3"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-HN4SQRP2M3');
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(aboutInformation.jsonLd)} />

  <title>{aboutInformation.firstName} {aboutInformation.lastName} - About Me</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0e0f13;
      --surface: #14161d;
      --surface2: #1c1f2b;
      --surface3: #222638;
      --border: rgba(255,255,255,0.07);
      --border2: rgba(255,255,255,0.12);
      --accent: #4f8ef7;
      --accent2: #a78bfa;
      --text: #e8eaf0;
      --muted: #6b7280;
      --gold: #c9a84c;
      --green: #34d399;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lato', sans-serif;
      background-color: var(--bg);
      color: var(--text);
      line-height: 1.7;
      min-height: 100vh;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 0; opacity: 0.4;
    }

    /* ── HEADER ── */
    header {
      position: sticky; top: 0; padding: 2.5rem 3rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(180deg, rgba(79,142,247,0.04) 0%, transparent 100%);
      z-index: 10;
    }
    .header-name { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; color: var(--accent); }
    .header-name span { color: var(--accent); }
    .header-title { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; letter-spacing: 0.3em; color: var(--muted); text-transform: uppercase; margin: 0.5rem 0 0 0; }

    /* Fluid Navigation Styles */
    .fluid-nav {
      position: relative;
      width: 64px;
      height: 64px;
    }

    .nav-toggle {
      display: none;
    }

    .nav-toggle-label {
      position: absolute;
      top: 0;
      left: 0;
      width: 64px;
      height: 64px;
      background: var(--surface);
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 10;
      transition: background 0.3s ease;
    }

    .nav-toggle-label:hover {
      background: var(--surface2);
    }

    .hamburger {
      width: 24px;
      height: 24px;
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    .hamburger span {
      width: 18px;
      height: 2px;
      background: var(--text);
      margin: 2px 0;
      transition: all 0.3s ease;
      transform-origin: center;
    }

    .nav-toggle:checked + .nav-toggle-label .hamburger span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }

    .nav-toggle:checked + .nav-toggle-label .hamburger span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle:checked + .nav-toggle-label .hamburger span:nth-child(3) {
      transform: rotate(-45deg) translate(7px, -6px);
    }

    .nav-menu {
      position: absolute;
      top: 0;
      left: 0;
      width: 64px;
      height: 64px;
    }

    .nav-item {
      position: absolute;
      top: 0;
      left: 0;
      width: 64px;
      height: 64px;
      background: var(--surface);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      color: var(--text);
      font-size: 20px;
      transition: all 0.3s ease;
      z-index: 1;
      opacity: 0;
      transform: scale(0);
    }

    .nav-item:hover {
      background: var(--surface2);
      transform: scale(1.1);
    }

    /* Show menu items when toggle is checked */
    .nav-toggle:checked ~ .nav-menu .nav-item:nth-child(1) {
    opacity: 1;
    transform: translateY(72px) scale(1);
    transition-delay: 0.1s;
    } 

    .nav-toggle:checked ~ .nav-menu .nav-item:nth-child(2) {
      opacity: 1;
      transform: translateY(144px) scale(1);
      transition-delay: 0.2s;
    }

    .nav-toggle:checked ~ .nav-menu .nav-item:nth-child(3) {
      opacity: 1;
      transform: translateY(216px) scale(1);
      transition-delay: 0.3s;
    }

    .nav-toggle:checked ~ .nav-menu .nav-item:nth-child(4) {
      opacity: 1;
      transform: translateY(288px) scale(1);
      transition-delay: 0.4s;
    }

    /* ── HERO ── */
    .hero { padding: 5rem 3rem 2rem; max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }
    .eyebrow {
      font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
      letter-spacing: 0.2em; color: var(--accent); text-transform: uppercase;
      margin-bottom: 1.2rem; display: flex; align-items: center; gap: 0.8rem;
    }
    .eyebrow::after { content: ''; flex: 1; max-width: 60px; height: 1px; background: var(--accent); opacity: 0.4; }
    .hero h1 {
      font-family: 'Playfair Display', serif; font-size: clamp(2.8rem, 6vw, 4.5rem);
      font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 1rem;
    }
    .hero h1 em { font-style: italic; color: var(--accent2); }
    .hero-sub {
      font-size: 1rem; color: var(--muted); max-width: 480px; line-height: 1.8;
    }

    /* ── MAIN CONTENT ── */
    #research {
      background-color: #1f354c;
      color: #1e293b;
    }

    #publications {
      background-color: #172431;
      color: #1e293b;
    }

    main section {
      margin: 0;
    }

    .contact-section {
      padding: 4rem 3rem 6rem;
      max-width: 900px; 
      margin: 0 auto;
      position: relative; z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    /* ── CONTACT LIST ITEMS ── same .pub-list-item format ── */
    .contact-item {
      display: grid;
      grid-template-columns: 36px 1fr auto;
      gap: 0 1.25rem;
      padding: 1.4rem 0.75rem;
      border-bottom: 1px solid var(--border);
      border-radius: 12px;
      padding: 0 0.5rem;
      cursor: pointer;
      transition: background 0.2s;
      text-decoration: none;
      color: inherit;
      align-items: center;
    }
    .contact-item:last-child { border-bottom: none; }
    .contact-item:hover { background: var(--surface2); }
    .contact-item:hover .ci-label { color: var(--accent); }
    .contact-item:hover .ci-icon-wrap { background: rgba(79,142,247,0.2); border-color: rgba(79,142,247,0.4); }
    .contact-item:hover .ci-icon-wrap svg { color: var(--accent); }
    .contact-item:hover .ci-arrow { opacity: 1; transform: translateX(0); color: var(--accent); }

    .ci-icon-wrap {
      width: 36px; height: 36px;
      border-radius: 8px;
      background: rgba(79,142,247,0.08);
      border: 1px solid var(--border2);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      transition: background 0.2s, border-color 0.2s;
    }
    .ci-icon-wrap svg { width: 16px; height: 16px; color: var(--muted); transition: color 0.2s; }

    .ci-body { min-width: 0; }
    .ci-type {
      font-family: 'JetBrains Mono', monospace; font-size: 0.6rem;
      color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase;
      margin-bottom: 0.15rem;
    }
    .ci-label {
      font-family: 'Playfair Display', serif; font-size: 0.95rem; font-weight: 700;
      color: var(--text); transition: color 0.2s;
      line-height: 1.3;
    }
    .ci-sublabel {
      font-family: 'JetBrains Mono', monospace; font-size: 0.68rem;
      color: var(--muted); margin-top: 0.1rem;
    }

    .ci-arrow {
      opacity: 0;
      transform: translateX(-6px);
      transition: opacity 0.2s, transform 0.2s, color 0.2s;
      flex-shrink: 0;
    }
    .ci-arrow svg { width: 16px; height: 16px; }

    /* ── FOOTER ── */
    footer { border-top: 1px solid var(--border); padding: 2rem 3rem; position: relative; z-index: 1; }
    .footer-inner { max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
    .footer-copy { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: var(--muted); letter-spacing: 0.05em; }
    .footer-social { display: flex; gap: 0.5rem; }
    .footer-social a { width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; border-radius: 8px; border: 1px solid var(--border); color: var(--muted); background: var(--surface); transition: all 0.2s; }
    .footer-social a:hover { color: var(--accent); border-color: rgba(79,142,247,0.4); background: var(--surface2); }
    .footer-social svg { width: 15px; height: 15px; }

    @media (max-width: 700px) {
      header { flex-direction: column; gap: 1.5rem; padding: 2rem 1.5rem; }
      .hero, .contact-section { padding-left: 1.5rem; padding-right: 1.5rem; }
      .footer-inner { flex-direction: column; gap: 1.5rem; align-items: center; }
      .contact-item { grid-template-columns: 36px 1fr; }
      .ci-arrow { display: none; }
    }
  </style>
</head>
<body>

  <header>
    <div>
      <div class="header-name">{aboutInformation.firstName} <span>{aboutInformation.lastName}</span></div>
      <p class="header-title">{aboutInformation.title}</p>
    </div>
    <div class="fluid-nav">
      <input type="checkbox" id="nav-toggle" class="nav-toggle">
      <label for="nav-toggle" class="nav-toggle-label">
        <div class="hamburger">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </label>
      <nav class="nav-menu">
        <a href="#about" class="nav-item" data-icon="👤">
          <span class="nav-icon">👤</span>
        </a>
        <a href="#research" class="nav-item" data-icon="🔬">
          <span class="nav-icon">🔬</span>
        </a>
        <a href="#publications" class="nav-item" data-icon="📝">
          <span class="nav-icon">📝</span>
        </a>
        <a href="#contact" class="nav-item" data-icon="✉️">
          <span class="nav-icon">✉️</span>
        </a>
      </nav>
    </div>
  </header>

  <main>
    <section id="about">
      <About />
    </section>
    <section id="research">
      <Research />
    </section>
    <section id="publications">
      <Publications />
    </section>
    <section id="contact">
      <Contact />
    </section>
  </main>

  <footer>
    <div class="footer-inner">
      <p class="footer-copy">&copy; <script>document.write(new Date().getFullYear())</script> Advik Vira · Georgia Institute of Technology</p>
      <div class="footer-social">
        <a href={`mailto:${aboutInformation.email}`} aria-label="Email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>
        </a>
        <a href={aboutInformation.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href={aboutInformation.googlescholar} target="_blank" rel="noopener noreferrer" aria-label="Google Scholar">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 10a8 8 0 0 1 7.162 3.44L24 9.5z"/>
          </svg>
        </a>
        <a href={aboutInformation.orcid} target="_blank" rel="noopener noreferrer" aria-label="ORCID">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.516.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.016-5.325 5.016h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>
        </a>
        <a href={aboutInformation.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>
        </a>
      </div>
    </div>
  </footer>
</body>
 
</style>
